# Ignore temporary Docker execution directories or outputs
data/output/*
!data/output/.gitkeep
tmp/
temp/

# Ignore Langfuse/Loguru logs
logs/
*.log
!runs/_dev/dev.log
# Ignore run artifacts (checkpoints, logs)
runs/

