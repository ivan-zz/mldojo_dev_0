# =========================
# Data, Caches & Outputs (MLE-STAR Specific)
# =========================
# Ignore downloaded Kaggle datasets and temporary sandbox files
data/input/*
!data/input/.gitkeep

# 
data/generated_scripts/*
!data/input/.gitkeep

# Ignore LLM JSON checkpoints to prevent committing bulky/stale state
data/checkpoints/*
